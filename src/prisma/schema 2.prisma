// NiNKU BOXX - 人事制度プロダクト Prisma Schema
// ブルーカラー企業向け等級制度・評価制度構築Webアプリケーション

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// Enums（列挙型）
// ============================================

// ユーザーロール
enum UserRole {
  ADMIN // NiNKU BOXX管理者（全社横断アクセス）
  COMPANY_ADMIN // クライアント企業の管理者（自社のみアクセス）
  EVALUATOR // 評価者（評価入力権限）
  EMPLOYEE // 一般従業員（自己評価・閲覧のみ）
}

// 雇用形態
enum EmploymentType {
  FULL_TIME // 正社員
  CONTRACT // 契約社員
  OUTSOURCE // 業務委託
  PART_TIME // パート
}

// 従業員ステータス
enum EmployeeStatus {
  ACTIVE // 在籍中
  LEAVE // 休職中
  RETIRED // 退職
}

// 性別
enum Gender {
  MALE // 男性
  FEMALE // 女性
  OTHER // その他
}

// 評価周期
enum EvaluationCycle {
  HALF_YEARLY // 半期
  YEARLY // 年次
}

// 評価期間タイプ
enum PeriodType {
  FIRST_HALF // 上期
  SECOND_HALF // 下期
}

// 評価ステータス（6段階）
enum EvaluationStatus {
  STARTED // 開始
  PREPARING // 配布準備
  DISTRIBUTED // 配布完了
  COLLECTED // 回収済み
  AGGREGATING // 集計
  COMPLETED // 完了
}

// 評価レート（S/A/B/C/D）
enum EvaluationRating {
  S // 非常に優秀
  A // 優秀
  B // 標準
  C // 要改善
  D // 不十分
}

// ============================================
// NextAuth.js 認証関連テーブル
// ============================================

// ユーザー
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  password      String? // ハッシュ化されたパスワード
  name          String?
  image         String?
  role          UserRole  @default(EMPLOYEE)
  companyId     String?   @map("company_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // リレーション
  company               Company?               @relation(fields: [companyId], references: [id], onDelete: SetNull)
  accounts              Account[]
  sessions              Session[]
  employee              Employee?
  individualEvaluations IndividualEvaluation[] @relation("Evaluator")
  evaluatorAssignments  EvaluatorAssignment[]

  @@map("users")
}

// OAuth アカウント（NextAuth.js用）
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// セッション（NextAuth.js用）
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// メール認証トークン（NextAuth.js用）
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================
// 会社・組織関連テーブル
// ============================================

// 会社
model Company {
  id                    String          @id @default(cuid())
  name                  String // 会社名
  address               String? // 所在地
  representative        String? // 代表者
  establishedDate       DateTime?       @map("established_date") // 設立日
  businessDescription   String?         @map("business_description") @db.Text // 事業内容
  evaluationCycle       EvaluationCycle @default(HALF_YEARLY) @map("evaluation_cycle") // 評価周期
  salaryReflectionMonth Int?            @map("salary_reflection_month") // 号俸反映月（1-12）
  salaryReflectionDay   Int?            @map("salary_reflection_day") // 号俸反映日（1-31）
  evaluationPeriodStart DateTime?       @map("evaluation_period_start") // 評価期間開始日
  evaluationPeriodEnd   DateTime?       @map("evaluation_period_end") // 評価期間終了日
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  // リレーション
  users                   User[]
  departments             Department[]
  positions               Position[]
  jobCategories           JobCategory[]
  grades                  Grade[]
  salaryTables            SalaryTable[]
  employees               Employee[]
  evaluationPeriods       EvaluationPeriod[]
  evaluationCriteria      EvaluationCriteria[]
  bonusSettings           BonusSetting[]
  evaluation360Templates  Evaluation360Template[]
  evaluation360Records    Evaluation360Record[]
  evaluationScoringMethod  EvaluationScoringMethod?
  evaluationCustomItems    EvaluationCustomItem[]
  employeeEvaluationWeights EmployeeEvaluationWeight[]

  @@map("companies")
}

// 部署
model Department {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  name      String // 部署名
  parentId  String?  @map("parent_id") // 親部署ID（階層構造用）
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // リレーション
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent    Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  Department[] @relation("DepartmentHierarchy")
  employees Employee[]

  @@index([companyId])
  @@index([parentId])
  @@map("departments")
}

// 役職
model Position {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  name      String // 役職名（部長、次長・課長、職長など）
  level     Int // 役職レベル（数値が大きいほど上位）
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // リレーション
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees Employee[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("positions")
}

// ============================================
// 職種関連テーブル
// ============================================

// 職種大分類（例：現場、管理）
model JobCategory {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  name      String // 大分類名
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // リレーション
  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobTypes JobType[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("job_categories")
}

// 職種小分類（例：多能工、ドライバー、オペレーター、解体D）
model JobType {
  id            String   @id @default(cuid())
  jobCategoryId String   @map("job_category_id")
  name          String // 小分類名
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // リレーション
  jobCategory                   JobCategory                    @relation(fields: [jobCategoryId], references: [id], onDelete: Cascade)
  gradeJobTypeConfigs           GradeJobTypeConfig[]
  employees                     Employee[]
  evaluation360TemplateJobTypes Evaluation360TemplateJobType[]

  @@unique([jobCategoryId, name])
  @@index([jobCategoryId])
  @@map("job_types")
}

// ============================================
// 等級関連テーブル
// ============================================

// 等級
model Grade {
  id             String         @id @default(cuid())
  companyId      String         @map("company_id")
  name           String // 等級名（正1、正2、正3等）
  level          Int // 等級レベル（数値が大きいほど上位）
  employmentType EmploymentType @map("employment_type") // 対応する雇用形態
  isManagement   Boolean        @default(false) @map("is_management") // 管理職かどうか
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  // リレーション
  company                     Company                      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  gradeJobTypeConfigs         GradeJobTypeConfig[]
  salaryTableEntries          SalaryTableEntry[]
  employees                   Employee[]
  employeeGradeHistory        EmployeeGradeHistory[]
  gradeAdjustmentRules        GradeAdjustmentRule[]
  evaluation360TemplateGrades Evaluation360TemplateGrade[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("grades")
}

// 等級×職種の有効/無効設定
model GradeJobTypeConfig {
  id        String   @id @default(cuid())
  gradeId   String   @map("grade_id")
  jobTypeId String   @map("job_type_id")
  isEnabled Boolean  @default(true) @map("is_enabled") // 有効/無効
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // リレーション
  grade              Grade               @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  jobType            JobType             @relation(fields: [jobTypeId], references: [id], onDelete: Cascade)
  gradeRole          GradeRole?
  evaluationItems    EvaluationItem[]
  evaluationTemplate EvaluationTemplate?

  @@unique([gradeId, jobTypeId])
  @@index([gradeId])
  @@index([jobTypeId])
  @@map("grade_job_type_configs")
}

// 等級×職種別の役割責任
model GradeRole {
  id                   String   @id @default(cuid())
  gradeJobTypeConfigId String   @unique @map("grade_job_type_config_id")
  responsibilities     Json // 役割責任リスト（JSON配列）
  positionNames        String[] @map("position_names") // 該当役職名の配列
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // リレーション
  gradeJobTypeConfig GradeJobTypeConfig @relation(fields: [gradeJobTypeConfigId], references: [id], onDelete: Cascade)

  @@map("grade_roles")
}

// ============================================
// 号俸テーブル関連
// ============================================

// 号俸テーブル
model SalaryTable {
  id              String   @id @default(cuid())
  companyId       String   @map("company_id")
  name            String // テーブル名
  baseSalaryMax   Int      @map("base_salary_max") // 基本給MAX
  baseSalaryMin   Int      @map("base_salary_min") // 基本給MIN
  rankDivision    Int      @map("rank_division") // 各等級内のランク数
  increaseRate    Float    @map("increase_rate") // ランク間増加率
  initialStepDiff Int      @map("initial_step_diff") // 初期号差
  totalRanks      Int      @map("total_ranks") // 全体のランク数
  isActive        Boolean  @default(true) @map("is_active") // 有効かどうか
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // リレーション
  company               Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entries               SalaryTableEntry[]
  salaryAdjustmentRules SalaryAdjustmentRule[]

  @@index([companyId])
  @@map("salary_tables")
}

// 号俸改定ルール（評価レート×現賃金ランク→号俸帯別の改定値）
model SalaryAdjustmentRule {
  id              String   @id @default(cuid())
  salaryTableId   String   @map("salary_table_id")
  currentBand     Int      @map("current_band") // 現賃金ランク（号俸帯番号 1〜15）
  isTransition    Boolean  @map("is_transition") // Tランクかどうか
  targetBand      Int      @map("target_band") // 対象号俸帯（1〜15）
  adjustmentValue Int      @map("adjustment_value") // 変動値（+3, -1, 0 など）
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // リレーション
  salaryTable SalaryTable @relation(fields: [salaryTableId], references: [id], onDelete: Cascade)

  @@unique([salaryTableId, currentBand, isTransition, targetBand])
  @@index([salaryTableId])
  @@map("salary_adjustment_rules")
}

// 号俸テーブルエントリ（号俸 × 等級の基本給）
model SalaryTableEntry {
  id            String   @id @default(cuid())
  salaryTableId String   @map("salary_table_id")
  gradeId       String   @map("grade_id")
  stepNumber    Int      @map("step_number") // 号俸
  rank          String // ランク（S1, S2, A1, B1等）
  baseSalary    Int      @map("base_salary") // 基本給
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // リレーション
  salaryTable      SalaryTable      @relation(fields: [salaryTableId], references: [id], onDelete: Cascade)
  grade            Grade            @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  employeeSalaries EmployeeSalary[]

  @@unique([salaryTableId, gradeId, stepNumber])
  @@index([salaryTableId])
  @@index([gradeId])
  @@map("salary_table_entries")
}

// ============================================
// 従業員関連テーブル
// ============================================

// 従業員
model Employee {
  id             String         @id @default(cuid())
  companyId      String         @map("company_id")
  userId         String?        @unique @map("user_id") // Userと1:1で紐付け（任意）
  employeeCode   String         @map("employee_code") // 従業員ID
  firstName      String         @map("first_name") // 名
  lastName       String         @map("last_name") // 姓
  gender         Gender? // 性別
  birthDate      DateTime?      @map("birth_date") // 生年月日
  hireDate       DateTime       @map("hire_date") // 入社日
  departmentId   String?        @map("department_id")
  employmentType EmploymentType @map("employment_type") // 雇用形態
  jobTypeId      String?        @map("job_type_id")
  gradeId        String?        @map("grade_id")
  positionId     String?        @map("position_id")
  currentStep    Int?           @map("current_step") // 現在の号俸
  currentRank    String?        @map("current_rank") // 現在のランク
  baseSalary     Int?           @map("base_salary") // 基本給
  status         EmployeeStatus @default(ACTIVE) // 在籍ステータス
  profileImage   String?        @map("profile_image") // プロフィール画像URL
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  // リレーション
  company                          Company                           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user                             User?                             @relation(fields: [userId], references: [id], onDelete: SetNull)
  department                       Department?                       @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  jobType                          JobType?                          @relation(fields: [jobTypeId], references: [id], onDelete: SetNull)
  grade                            Grade?                            @relation(fields: [gradeId], references: [id], onDelete: SetNull)
  position                         Position?                         @relation(fields: [positionId], references: [id], onDelete: SetNull)
  gradeHistory                     EmployeeGradeHistory[]
  interviewRecords                 InterviewRecord[]
  salaryHistory                    EmployeeSalary[]
  individualEvaluations            IndividualEvaluation[]            @relation("Evaluatee")
  evaluation360s                   Evaluation360[]
  employeeEvaluations              EmployeeEvaluation[]              @relation("EmployeeEvaluations")
  evaluatorEvaluations             EmployeeEvaluation[]              @relation("EvaluatorEvaluations")
  employee360Items                 Employee360EvaluationItem[]
  evaluation360Records             Evaluation360Record[]             @relation("Evaluation360RecordEmployee")
  evaluation360ReviewerAssignments Evaluation360ReviewerAssignment[] @relation("Evaluation360Reviewer")
  evaluationCustomItems            EvaluationCustomItem[]
  evaluationWeights                EmployeeEvaluationWeight[]

  @@unique([companyId, employeeCode])
  @@index([companyId])
  @@index([departmentId])
  @@index([jobTypeId])
  @@index([gradeId])
  @@map("employees")
}

// 従業員等級変遷履歴
model EmployeeGradeHistory {
  id            String   @id @default(cuid())
  employeeId    String   @map("employee_id")
  gradeId       String   @map("grade_id")
  effectiveDate DateTime @map("effective_date") // 適用日
  reason        String? // 変更理由
  createdAt     DateTime @default(now()) @map("created_at")

  // リレーション
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  grade    Grade    @relation(fields: [gradeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([gradeId])
  @@map("employee_grade_history")
}

// 面談記録
model InterviewRecord {
  id            String   @id @default(cuid())
  employeeId    String   @map("employee_id")
  interviewDate DateTime @map("interview_date") // 面談日
  notes         String?  @db.Text // 面談メモ
  documentUrl   String?  @map("document_url") // 議事録URL（Google Drive等）
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // リレーション
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("interview_records")
}

// 従業員給与情報
model EmployeeSalary {
  id                 String   @id @default(cuid())
  employeeId         String   @map("employee_id")
  salaryTableEntryId String   @map("salary_table_entry_id")
  effectiveDate      DateTime @map("effective_date") // 適用日
  baseSalary         Int      @map("base_salary") // 基本給
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // リレーション
  employee         Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  salaryTableEntry SalaryTableEntry @relation(fields: [salaryTableEntryId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([salaryTableEntryId])
  @@map("employee_salaries")
}

// ============================================
// 評価関連テーブル
// ============================================

// 評価期間
model EvaluationPeriod {
  id         String           @id @default(cuid())
  companyId  String           @map("company_id")
  name       String // 評価期間名（例：2024年度上期）
  periodType PeriodType       @map("period_type") // 上期/下期
  startDate  DateTime         @map("start_date") // 開始日
  endDate    DateTime         @map("end_date") // 終了日
  status     EvaluationStatus @default(STARTED) // 評価ステータス（6段階）
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  // リレーション
  company               Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  individualEvaluations IndividualEvaluation[]
  evaluation360s        Evaluation360[]
  evaluation360Records      Evaluation360Record[]
  evaluationCustomItems     EvaluationCustomItem[]
  employeeEvaluationWeights EmployeeEvaluationWeight[]

  @@index([companyId])
  @@map("evaluation_periods")
}

// 個別評価（上司評価）
model IndividualEvaluation {
  id                 String            @id @default(cuid())
  evaluationPeriodId String            @map("evaluation_period_id")
  employeeId         String            @map("employee_id") // 被評価者
  evaluatorId        String            @map("evaluator_id") // 評価者（User）
  status             EvaluationStatus  @default(STARTED) // 評価ステータス（6段階）
  totalScore         Float?            @map("total_score") // 合計スコア
  finalRating        EvaluationRating? @map("final_rating") // 最終評価レート
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  // リレーション
  evaluationPeriod EvaluationPeriod  @relation(fields: [evaluationPeriodId], references: [id], onDelete: Cascade)
  employee         Employee          @relation("Evaluatee", fields: [employeeId], references: [id], onDelete: Cascade)
  evaluator        User              @relation("Evaluator", fields: [evaluatorId], references: [id], onDelete: Cascade)
  scores           EvaluationScore[]

  @@unique([evaluationPeriodId, employeeId])
  @@index([evaluationPeriodId])
  @@index([employeeId])
  @@index([evaluatorId])
  @@map("individual_evaluations")
}

// 評価項目
model EvaluationItem {
  id                   String   @id @default(cuid())
  name                 String // 評価項目名
  description          String?  @db.Text // 説明
  category             String // カテゴリ（計画・管理、安全への取り組み等）
  weight               Float? // 重み（配点割合）
  gradeJobTypeConfigId String?  @map("grade_job_type_config_id") // 等級×職種との紐付け（オプション）
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // リレーション
  gradeJobTypeConfig GradeJobTypeConfig? @relation(fields: [gradeJobTypeConfigId], references: [id], onDelete: SetNull)
  evaluationScores   EvaluationScore[]

  @@index([gradeJobTypeConfigId])
  @@map("evaluation_items")
}

// 評価スコア
model EvaluationScore {
  id                     String   @id @default(cuid())
  individualEvaluationId String   @map("individual_evaluation_id")
  evaluationItemId       String   @map("evaluation_item_id")
  selfScore              Int?     @map("self_score") // 自己評価スコア（0-5）
  evaluatorScore         Int?     @map("evaluator_score") // 評価者スコア（0-5）
  comment                String?  @db.Text // コメント
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  // リレーション
  individualEvaluation IndividualEvaluation @relation(fields: [individualEvaluationId], references: [id], onDelete: Cascade)
  evaluationItem       EvaluationItem       @relation(fields: [evaluationItemId], references: [id], onDelete: Cascade)

  @@unique([individualEvaluationId, evaluationItemId])
  @@index([individualEvaluationId])
  @@index([evaluationItemId])
  @@map("evaluation_scores")
}

// ============================================
// 360度評価関連テーブル
// ============================================

// 360度評価
model Evaluation360 {
  id                 String           @id @default(cuid())
  evaluationPeriodId String           @map("evaluation_period_id")
  employeeId         String           @map("employee_id") // 被評価者
  status             EvaluationStatus @default(STARTED) // 評価ステータス（6段階）
  averageScore       Float?           @map("average_score") // 平均スコア
  feedback           String?          @db.Text // フィードバック
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  // リレーション
  evaluationPeriod     EvaluationPeriod      @relation(fields: [evaluationPeriodId], references: [id], onDelete: Cascade)
  employee             Employee              @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  evaluatorAssignments EvaluatorAssignment[]

  @@unique([evaluationPeriodId, employeeId])
  @@index([evaluationPeriodId])
  @@index([employeeId])
  @@map("evaluation_360s")
}

// 評価者割当（360度評価用）
model EvaluatorAssignment {
  id              String   @id @default(cuid())
  evaluation360Id String   @map("evaluation_360_id")
  evaluatorId     String   @map("evaluator_id") // 評価者（User）
  order           Int // 評価者順序（1〜4）
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // リレーション
  evaluation360 Evaluation360 @relation(fields: [evaluation360Id], references: [id], onDelete: Cascade)
  evaluator     User          @relation(fields: [evaluatorId], references: [id], onDelete: Cascade)

  @@unique([evaluation360Id, evaluatorId])
  @@unique([evaluation360Id, order])
  @@index([evaluation360Id])
  @@index([evaluatorId])
  @@map("evaluator_assignments")
}

// 360度評価スコア（評価者×項目）
model Evaluation360Score {
  id                     String   @id @default(cuid())
  evaluationCustomItemId String   @map("evaluation_custom_item_id")
  reviewerAssignmentId   String   @map("reviewer_assignment_id")
  score                  Float? // 評価点（マイナス値も可能）
  comment                String?  @db.Text // コメント
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  // リレーション
  evaluationCustomItem EvaluationCustomItem            @relation(fields: [evaluationCustomItemId], references: [id], onDelete: Cascade)
  reviewerAssignment   Evaluation360ReviewerAssignment @relation(fields: [reviewerAssignmentId], references: [id], onDelete: Cascade)

  @@unique([evaluationCustomItemId, reviewerAssignmentId])
  @@index([evaluationCustomItemId])
  @@index([reviewerAssignmentId])
  @@map("evaluation_360_scores")
}

// ============================================
// 評価基準・昇降格ロジック関連テーブル
// ============================================

// 評価基準マトリクス（前期×後期の組み合わせによる最終評価）
model EvaluationCriteria {
  id               String           @id @default(cuid())
  companyId        String           @map("company_id")
  firstHalfRating  EvaluationRating @map("first_half_rating") // 前期評価
  secondHalfRating EvaluationRating @map("second_half_rating") // 後期評価
  finalRating      EvaluationRating @map("final_rating") // 最終評価
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  // リレーション
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, firstHalfRating, secondHalfRating])
  @@index([companyId])
  @@map("evaluation_criteria")
}

// 等級別号俸改定基準（評価レート×現賃金ランクの改定値）
model GradeAdjustmentRule {
  id             String           @id @default(cuid())
  gradeId        String           @map("grade_id")
  currentRank    String           @map("current_rank") // 現在のランク
  rating         EvaluationRating // 評価レート
  stepAdjustment Int              @map("step_adjustment") // 号俸変動値（+/-）
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  // リレーション
  grade Grade @relation(fields: [gradeId], references: [id], onDelete: Cascade)

  @@unique([gradeId, currentRank, rating])
  @@index([gradeId])
  @@map("grade_adjustment_rules")
}

// ============================================
// 評価テンプレート関連テーブル
// ============================================

// 評価テンプレート（等級×職種ごとに定義）
model EvaluationTemplate {
  id                   String   @id @default(cuid())
  gradeJobTypeConfigId String   @map("grade_job_type_config_id")
  name                 String // テンプレート名
  description          String?  @db.Text // 説明
  isActive             Boolean  @default(true) @map("is_active") // 有効/無効
  status               String   @default("draft") // draft | confirmed
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // リレーション
  gradeJobTypeConfig  GradeJobTypeConfig       @relation(fields: [gradeJobTypeConfigId], references: [id], onDelete: Cascade)
  items               EvaluationTemplateItem[]
  employeeEvaluations EmployeeEvaluation[]

  @@unique([gradeJobTypeConfigId])
  @@index([gradeJobTypeConfigId])
  @@map("evaluation_templates")
}

// 評価テンプレート項目
model EvaluationTemplateItem {
  id                   String   @id @default(cuid())
  evaluationTemplateId String   @map("evaluation_template_id")
  name                 String // 項目名
  description          String?  @db.Text // 説明・基準
  category             String // カテゴリ（計画・管理、安全への取り組み等）
  maxScore             Int      @default(5) @map("max_score") // 最大スコア
  weight               Float    @default(1.0) // 重み（配点割合）
  sortOrder            Int      @default(0) @map("sort_order") // 表示順
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // リレーション
  evaluationTemplate      EvaluationTemplate       @relation(fields: [evaluationTemplateId], references: [id], onDelete: Cascade)
  employeeEvaluationItems EmployeeEvaluationItem[]

  @@index([evaluationTemplateId])
  @@map("evaluation_template_items")
}

// 従業員評価（実際の評価記録）
model EmployeeEvaluation {
  id                   String            @id @default(cuid())
  employeeId           String            @map("employee_id")
  evaluatorId          String?           @map("evaluator_id") // 評価者（従業員）
  evaluationTemplateId String            @map("evaluation_template_id")
  evaluationPeriodId   String?           @map("evaluation_period_id")
  evaluationType       String            @default("individual") @map("evaluation_type") // "individual" or "360"
  status               EvaluationStatus  @default(STARTED)
  totalScore           Float?            @map("total_score")
  finalRating          EvaluationRating? @map("final_rating")
  evaluatorComment     String?           @map("evaluator_comment") @db.Text // 評価者コメント
  selfComment          String?           @map("self_comment") @db.Text // 自己評価コメント
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")

  // リレーション
  employee           Employee                 @relation("EmployeeEvaluations", fields: [employeeId], references: [id], onDelete: Cascade)
  evaluator          Employee?                @relation("EvaluatorEvaluations", fields: [evaluatorId], references: [id], onDelete: SetNull)
  evaluationTemplate EvaluationTemplate       @relation(fields: [evaluationTemplateId], references: [id], onDelete: Cascade)
  items              EmployeeEvaluationItem[]

  @@index([employeeId])
  @@index([evaluatorId])
  @@index([evaluationTemplateId])
  @@index([evaluationPeriodId])
  @@map("employee_evaluations")
}

// 従業員評価項目（各項目のスコア）
model EmployeeEvaluationItem {
  id                       String   @id @default(cuid())
  employeeEvaluationId     String   @map("employee_evaluation_id")
  evaluationTemplateItemId String   @map("evaluation_template_item_id")
  selfScore                Int?     @map("self_score") // 自己評価スコア
  evaluatorScore           Int?     @map("evaluator_score") // 評価者スコア
  comment                  String?  @db.Text // コメント
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  // リレーション
  employeeEvaluation     EmployeeEvaluation     @relation(fields: [employeeEvaluationId], references: [id], onDelete: Cascade)
  evaluationTemplateItem EvaluationTemplateItem @relation(fields: [evaluationTemplateItemId], references: [id], onDelete: Cascade)

  @@unique([employeeEvaluationId, evaluationTemplateItemId])
  @@index([employeeEvaluationId])
  @@index([evaluationTemplateItemId])
  @@map("employee_evaluation_items")
}

// ============================================
// 360度評価テンプレート関連テーブル
// ============================================

// 360度評価テンプレート
model Evaluation360Template {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  name        String   @default("") // テンプレート名
  description String?  @db.Text // 説明
  isActive    Boolean  @default(true) @map("is_active") // 有効/無効
  status      String   @default("draft") // "draft" | "confirmed"
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // リレーション
  company    Company                         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  grades     Evaluation360TemplateGrade[]
  jobTypes   Evaluation360TemplateJobType[]
  categories Evaluation360TemplateCategory[]

  @@index([companyId])
  @@map("evaluation_360_templates")
}

// 360度評価テンプレート対象等級
model Evaluation360TemplateGrade {
  id         String   @id @default(cuid())
  templateId String   @map("template_id")
  gradeId    String   @map("grade_id")
  createdAt  DateTime @default(now()) @map("created_at")

  // リレーション
  template Evaluation360Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  grade    Grade                 @relation(fields: [gradeId], references: [id], onDelete: Cascade)

  @@unique([templateId, gradeId])
  @@index([templateId])
  @@index([gradeId])
  @@map("evaluation_360_template_grades")
}

// 360度評価テンプレート対象職種
model Evaluation360TemplateJobType {
  id         String   @id @default(cuid())
  templateId String   @map("template_id")
  jobTypeId  String   @map("job_type_id")
  createdAt  DateTime @default(now()) @map("created_at")

  // リレーション
  template Evaluation360Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  jobType  JobType               @relation(fields: [jobTypeId], references: [id], onDelete: Cascade)

  @@unique([templateId, jobTypeId])
  @@index([templateId])
  @@index([jobTypeId])
  @@map("evaluation_360_template_job_types")
}

// 360度評価テンプレートカテゴリ
model Evaluation360TemplateCategory {
  id         String   @id @default(cuid())
  templateId String   @map("template_id")
  name       String // カテゴリ名
  sortOrder  Int      @default(0) @map("sort_order") // 表示順
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // リレーション
  template Evaluation360Template       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  items    Evaluation360TemplateItem[]

  @@index([templateId])
  @@map("evaluation_360_template_categories")
}

// 360度評価テンプレート項目
model Evaluation360TemplateItem {
  id         String   @id @default(cuid())
  categoryId String   @map("category_id")
  content    String   @db.Text // 評価項目内容
  maxScore   Int      @default(5) @map("max_score") // 満点（デフォルト5点）
  sortOrder  Int      @default(0) @map("sort_order") // 表示順（カテゴリ内）
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // リレーション
  category Evaluation360TemplateCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@map("evaluation_360_template_items")
}

// ============================================
// 賞与設定
// ============================================

// 賞与設定
model BonusSetting {
  id                  String   @id @default(cuid())
  companyId           String   @map("company_id")
  name                String // 賞与名（賞与1、賞与2等）
  assessmentStartDate DateTime @map("assessment_start_date") // 査定対象期間開始日
  assessmentEndDate   DateTime @map("assessment_end_date") // 査定対象期間終了日
  evaluationStartDate DateTime @map("evaluation_start_date") // 評価実施期間開始日
  evaluationEndDate   DateTime @map("evaluation_end_date") // 評価実施期間終了日
  paymentDate         DateTime @map("payment_date") // 支給日
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // リレーション
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("bonus_settings")
}

// ============================================
// 個人360度評価項目
// ============================================

// 従業員ごとの360度評価項目（テンプレートをコピーしてカスタマイズ可能）
model Employee360EvaluationItem {
  id            String   @id @default(cuid())
  employeeId    String   @map("employee_id")
  categoryName  String   @map("category_name") // カテゴリ名
  categoryOrder Int      @default(0) @map("category_order") // カテゴリ表示順
  content       String   @db.Text // 評価項目内容
  maxScore      Int      @default(5) @map("max_score") // 満点
  itemOrder     Int      @default(0) @map("item_order") // カテゴリ内の表示順
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // リレーション
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("employee_360_evaluation_items")
}

// ============================================
// 360度評価 運用フロー関連テーブル
// ============================================

// 360度評価運用レコード（被評価者ごと）
model Evaluation360Record {
  id                 String @id @default(cuid())
  evaluationPeriodId String @map("evaluation_period_id")
  employeeId         String @map("employee_id") // 被評価者
  companyId          String @map("company_id")

  // ステータス
  // "draft" | "preparing_items" | "preparing_reviewers" | "ready"
  // | "distributing" | "collecting" | "aggregated" | "completed"
  status String @default("draft")

  // 設定
  evaluationMethod String  @default("web") @map("evaluation_method") // "web" | "paper"
  isAnonymous      Boolean @default(true) @map("is_anonymous") // 匿名設定

  // 確定情報
  completedAt DateTime? @map("completed_at")
  completedBy String?   @map("completed_by")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // リレーション
  evaluationPeriod    EvaluationPeriod                  @relation(fields: [evaluationPeriodId], references: [id], onDelete: Cascade)
  employee            Employee                          @relation("Evaluation360RecordEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  company             Company                           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reviewerAssignments Evaluation360ReviewerAssignment[]

  @@unique([evaluationPeriodId, employeeId])
  @@index([companyId])
  @@index([evaluationPeriodId])
  @@index([employeeId])
  @@map("evaluation_360_records")
}

// 360度評価評価者アサイン
model Evaluation360ReviewerAssignment {
  id         String @id @default(cuid())
  recordId   String @map("record_id")
  reviewerId String @map("reviewer_id") // 評価者のemployeeId

  // 評価者ステータス: "not_started" | "in_progress" | "submitted"
  status      String    @default("not_started")
  submittedAt DateTime? @map("submitted_at")
  comment     String?   @db.Text // 評価者のコメント

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // リレーション
  record   Evaluation360Record  @relation(fields: [recordId], references: [id], onDelete: Cascade)
  reviewer Employee             @relation("Evaluation360Reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  scores   Evaluation360Score[]

  @@unique([recordId, reviewerId])
  @@index([recordId])
  @@index([reviewerId])
  @@map("evaluation_360_reviewer_assignments")
}

// ============================================
// 算定方法（評価スコア算定）関連テーブル
// ============================================

// 算定方法（会社ごとに1つ）
model EvaluationScoringMethod {
  id                 String   @id @default(cuid())
  companyId          String   @unique @map("company_id") // 全社一律なので1:1
  normalizeToHundred Boolean  @default(true) @map("normalize_to_hundred") // true: 100点満点に正規化, false: 素点のまま
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // リレーション
  company Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ranks   EvaluationRank[]

  @@map("evaluation_scoring_methods")
}

// ランク定義
model EvaluationRank {
  id              String   @id @default(cuid())
  scoringMethodId String   @map("scoring_method_id")
  rankName        String   @map("rank_name") // "S", "A", "B", "C", "D" 固定名称
  sortOrder       Int      @map("sort_order") // 表示順（0=最高ランク）
  minScore        Float    @map("min_score") // この点数以上（inclusive）
  maxScore        Float?   @map("max_score") // この点数未満（exclusive）、最高ランクはnull（上限なし）
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // リレーション
  scoringMethod EvaluationScoringMethod @relation(fields: [scoringMethodId], references: [id], onDelete: Cascade)

  @@unique([scoringMethodId, rankName])
  @@index([scoringMethodId, sortOrder])
  @@map("evaluation_ranks")
}

// 従業員ごとの評価割合設定
model EmployeeEvaluationWeight {
  id         String  @id @default(cuid())
  companyId  String  @map("company_id")
  employeeId String  @map("employee_id")
  periodId   String? @map("period_id") // 評価期間ID（任意、期間ごとに変える場合）

  // 360度評価の割合（0〜100%）
  weight360 Int @default(100) @map("weight_360")
  // 個別評価の割合はAPIで 100 - weight360 として返す

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // リレーション
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee         Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  evaluationPeriod EvaluationPeriod? @relation(fields: [periodId], references: [id], onDelete: SetNull)

  @@unique([companyId, employeeId, periodId])
  @@index([companyId])
  @@index([employeeId])
  @@map("employee_evaluation_weights")
}

// ============================================
// 個人カスタマイズ評価項目（統一モデル）
// ============================================

// 個人カスタマイズされた評価項目（個別評価・360度評価共通）
model EvaluationCustomItem {
  id         String  @id @default(cuid())
  companyId  String  @map("company_id")
  employeeId String  @map("employee_id")
  periodId   String? @map("period_id")

  // 評価タイプ（個別 or 360度）
  evaluationType String @map("evaluation_type") // "individual" | "360"

  // 元テンプレート項目への参照（追加項目の場合はnull）
  sourceTemplateItemId String? @map("source_template_item_id")

  // 項目内容
  itemName    String  @map("item_name")
  description String? @db.Text
  maxScore    Float   @map("max_score")
  sortOrder   Int     @map("sort_order")

  // カテゴリー（360度はカテゴリー名あり、個別評価はnull）
  categoryName      String? @map("category_name")
  categorySortOrder Int?    @map("category_sort_order") // カテゴリーの表示順（360度用）

  // カスタマイズ状態
  isCustomized Boolean @default(false) @map("is_customized")
  isAdded      Boolean @default(false) @map("is_added")
  isDeleted    Boolean @default(false) @map("is_deleted")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // リレーション
  company          Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee         Employee             @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  evaluationPeriod EvaluationPeriod?    @relation(fields: [periodId], references: [id], onDelete: SetNull)
  scores           Evaluation360Score[]

  @@unique([employeeId, periodId, evaluationType, sourceTemplateItemId])
  @@index([employeeId, periodId, evaluationType])
  @@index([companyId])
  @@map("evaluation_custom_items")
}
